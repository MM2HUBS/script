local function createSlider(titleText, defaultValue, callback)
	local row = Instance.new("Frame")
	row.Size = UDim2.new(1, 0, 0, 70)
	row.BackgroundColor3 = PANEL
	row.BorderSizePixel = 0
	row.ZIndex = 999999
	row.Parent = buttonHolder

	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 12)

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0.5, 0, 0, 18)
	label.Position = UDim2.new(0, 12, 0, 8)
	label.BackgroundTransparency = 1
	label.Text = titleText
	label.Font = FONT_BOLD
	label.TextSize = 12
	label.TextColor3 = Color3.fromRGB(255, 255, 255)
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.ZIndex = 999999
	label.Parent = row

	local box = Instance.new("TextBox")
	box.Size = UDim2.new(0, 54, 0, 23)
	box.Position = UDim2.new(1, -65, 0, 7)
	box.BackgroundColor3 = Color3.fromRGB(12, 10, 18)
	box.Text = tostring(defaultValue)
	box.Font = FONT_BOLD
	box.TextSize = 11
	box.TextColor3 = Color3.fromRGB(255, 255, 255)
	box.ClearTextOnFocus = false
	box.ZIndex = 999999
	box.Parent = row

	Instance.new("UICorner", box).CornerRadius = UDim.new(0, 8)

	local bar = Instance.new("Frame")
	bar.Size = UDim2.new(1, -24, 0, 7)
	bar.Position = UDim2.new(0, 12, 0, 45)
	bar.BackgroundColor3 = Color3.fromRGB(35, 25, 55)
	bar.BorderSizePixel = 0
	bar.ZIndex = 999999
	bar.Parent = row

	Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)

	local fill = Instance.new("Frame")
	fill.Size = UDim2.new(defaultValue / 250, 0, 1, 0)
	fill.BackgroundColor3 = PURPLE
	fill.BorderSizePixel = 0
	fill.ZIndex = 999999
	fill.Parent = bar

	Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

	local knob = Instance.new("Frame")
	knob.Size = UDim2.new(0, 14, 0, 14)
	knob.Position = UDim2.new(defaultValue / 250, -7, 0.5, -7)
	knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	knob.BorderSizePixel = 0
	knob.ZIndex = 999999
	knob.Parent = bar

	Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

	local draggingSlider = false

	local function updateValue(x)
		local percent = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
		local value = math.floor(percent * 250)

		fill.Size = UDim2.new(percent, 0, 1, 0)
		knob.Position = UDim2.new(percent, -7, 0.5, -7)
		box.Text = tostring(value)

		callback(value)
	end

	bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			draggingSlider = true
			updateValue(input.Position.X)
		end
	end)

	UIS.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			draggingSlider = false
		end
	end)

	UIS.InputChanged:Connect(function(input)
		if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateValue(input.Position.X)
		end
	end)

	box.FocusLost:Connect(function()
		local value = math.clamp(tonumber(box.Text) or defaultValue, 0, 250)
		local percent = value / 250

		box.Text = tostring(value)
		fill.Size = UDim2.new(percent, 0, 1, 0)
		knob.Position = UDim2.new(percent, -7, 0.5, -7)

		callback(value)
	end)

	callback(defaultValue)
end

