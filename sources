local function switchPage(tabName)
	pageTitle.TextTransparency = 1
	buttonHolder.Position = UDim2.new(0, 20, 0, 40)

	clearContent()

	pageTitle.Text = tabName

	if tabName == "Main" then
		local shootBtn = makeButton("SHOOT MURDERER", 50)
		shootBtn.TextSize = 14
		shootBtn.MouseButton1Click:Connect(function()
			placeholderLoadstring("SHOOT MURDERER")
		end)

		local espBtn = makeButton("ESP", 50)
		espBtn.TextSize = 14
		espBtn.MouseButton1Click:Connect(function()
			placeholderLoadstring("ESP")
		end)

		local spawnerBtn = makeButton("Spawner (SOON)", 50)
		spawnerBtn.TextSize = 14
		spawnerBtn.MouseButton1Click:Connect(function()
			placeholderLoadstring("Spawner")
		end)

	elseif tabName == "Character" then
		createSlider("WalkSpeed", savedWalkSpeed, setWalkSpeed)
		createSlider("JumpPower", savedJumpPower, setJumpPower)

		local resetBtn = makeButton("Reset Character", 44)
		resetBtn.MouseButton1Click:Connect(resetCharacter)

	elseif tabName == "Freeze Trade" then
		local freeze = makeButton(freezeEnabled and "FREEZE : ON" or "FREEZE", 120)
		freeze.TextSize = 24
		freeze.TextColor3 = freezeEnabled and Color3.fromRGB(80, 255, 120) or Color3.fromRGB(255, 220, 40)

		if freezeEnabled then
			freeze.BackgroundColor3 = Color3.fromRGB(25, 60, 25)
		end

		freeze.MouseButton1Click:Connect(function()
			if not freezeEnabled then
				showFreezeWarning(freeze)
			end
		end)

	elseif tabName == "Settings" then
		local mini = makeButton("Minimize UI", 44)
		mini.MouseButton1Click:Connect(minimizeUI)

		local resize = makeButton("Resize UI", 44)
		resize.MouseButton1Click:Connect(resizeUI)

		local hint = makeButton("PC Toggle Key: Q", 44)
		hint.TextColor3 = Color3.fromRGB(180, 170, 200)
	end

	TweenService:Create(pageTitle, TweenInfo.new(0.2), {
		TextTransparency = 0
	}):Play()

	TweenService:Create(buttonHolder, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Position = UDim2.new(0, 0, 0, 40)
	}):Play()
end

local function makeTab(name)
	local tab = Instance.new("TextButton")
	tab.Size = UDim2.new(1, 0, 0, 32)
	tab.BackgroundColor3 = Color3.fromRGB(16, 13, 24)
	tab.Text = name
	tab.Font = FONT_BOLD
	tab.TextSize = 11
	tab.TextColor3 = Color3.fromRGB(225, 215, 245)
	tab.TextXAlignment = Enum.TextXAlignment.Left
	tab.AutoButtonColor = false
	tab.ZIndex = 999999
	tab.Parent = tabHolder

	Instance.new("UICorner", tab).CornerRadius = UDim.new(0, 9)

	local pad = Instance.new("UIPadding")
	pad.PaddingLeft = UDim.new(0, 10)
	pad.Parent = tab

	tab.MouseButton1Click:Connect(function()
		if activeTab then
			TweenService:Create(activeTab, TweenInfo.new(0.18), {
				BackgroundColor3 = Color3.fromRGB(16, 13, 24),
				Size = UDim2.new(1, 0, 0, 32)
			}):Play()
		end

		activeTab = tab

		TweenService:Create(tab, TweenInfo.new(0.18), {
			BackgroundColor3 = PURPLE,
			Size = UDim2.new(1, 0, 0, 36)
		}):Play()

		switchPage(name)
	end)

	return tab
end

