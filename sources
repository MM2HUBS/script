UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart

		main.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

local function openMainUI(device)
	if opening then return end

	opening = true
	selectedDevice = device

	questionLabel.Text = "Loading..."
	questionLabel.TextTransparency = 0
	welcomeLabel.Text = "Setting up UI..."
	creditIntro.TextTransparency = 1
	choiceHolder.Visible = false

	task.wait(1.2)

	TweenService:Create(introFrame, TweenInfo.new(0.35), {
		Size = UDim2.new(0, 0, 0, 0),
		Position = UDim2.new(0.5, 0, 0.5, 0),
		BackgroundTransparency = 1
	}):Play()

	task.wait(0.35)

	introFrame:Destroy()

	main.Visible = true
	main.Size = UDim2.new(0, 0, 0, 0)
	main.Position = UDim2.new(0.5, 0, 0.5, 0)

	TweenService:Create(main, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Size = currentSize,
		Position = currentPosition
	}):Play()

	createMainToggle()
end

pcButton.MouseButton1Click:Connect(function()
	openMainUI("PC")
end)

mobileButton.MouseButton1Click:Connect(function()
	openMainUI("Mobile")
end)

UIS.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end

	if selectedDevice == "PC" and input.KeyCode == Enum.KeyCode.Q then
		main.Visible = not main.Visible
	end
end)

