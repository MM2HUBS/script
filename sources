	welcomeLabel.Position = UDim2.new(0.5, 0, 0.42, -20)
	welcomeLabel.Size = UDim2.new(0, 470, 0, 120)
	welcomeLabel.TextSize = 46
	welcomeLabel.Text = "🔪 MM2 HUB ⚔️"
	welcomeLabel.TextTransparency = 1
	creditIntro.TextTransparency = 1
	questionLabel.TextTransparency = 1
	choiceHolder.Visible = false

	TweenService:Create(welcomeLabel, TweenInfo.new(0.5), {
		TextTransparency = 0
	}):Play()

	TweenService:Create(creditIntro, TweenInfo.new(0.5), {
		TextTransparency = 0
	}):Play()

	task.wait(2)

	TweenService:Create(welcomeLabel, TweenInfo.new(0.4), {
		TextTransparency = 1
	}):Play()

	TweenService:Create(creditIntro, TweenInfo.new(0.4), {
		TextTransparency = 1
	}):Play()

	task.wait(0.5)

	welcomeLabel.Position = UDim2.new(0.5, 0, 0.22, 0)
	welcomeLabel.Size = UDim2.new(0, 470, 0, 80)
	welcomeLabel.TextSize = 32

	local welcomeText = "Welcome, " .. player.Name .. "!"

	welcomeLabel.TextTransparency = 0
	welcomeLabel.Text = ""

	for i = 1, #welcomeText do
		welcomeLabel.Text = string.sub(welcomeText, 1, i)
		task.wait(0.035)
	end

	task.wait(0.35)

	TweenService:Create(questionLabel, TweenInfo.new(0.3), {
		TextTransparency = 0
	}):Play()

	task.wait(0.25)

	choiceHolder.Visible = true
end

